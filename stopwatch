<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Shared Stopwatch SSS.TTTTT</title>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    .mono {
      font-family: "Courier New", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      font-variant-numeric: tabular-nums;
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-slate-100">

  <!-- Card -->
  <div class="bg-white/95 backdrop-blur-xl p-8 rounded-2xl shadow-xl border border-slate-200 w-[90%] max-w-sm">
    <div class="text-center text-[11px] tracking-[0.22em] text-slate-500 uppercase mb-2">
      Shared Stopwatch
    </div>

    <!-- Display -->
    <div id="timeDisplay"
      class="mono text-center text-4xl sm:text-5xl font-semibold text-slate-900 bg-slate-50 border border-slate-200 rounded-xl py-5 mb-6">
      000.00000
    </div>

    <!-- Controls -->
    <div class="flex gap-3">
      <button id="startStopBtn"
        class="flex-1 py-2.5 rounded-full border border-sky-500 text-sky-600 font-medium tracking-[0.16em] uppercase text-[11px] hover:bg-sky-50 transition">
        Start
      </button>

      <button id="resetBtn"
        class="flex-1 py-2.5 rounded-full border border-slate-400 text-slate-600 font-medium tracking-[0.16em] uppercase text-[11px] hover:bg-slate-100 transition disabled:opacity-40"
        disabled>
        Reset
      </button>
    </div>

    <!-- Status -->
    <div id="status"
      class="text-center text-[10px] tracking-[0.22em] text-slate-400 uppercase mt-3">
      Connecting…
    </div>

    <div class="mt-3 text-[10px] text-center text-slate-400">
      Any device can control this timer. All open pages see the same time.
    </div>
  </div>

  <!-- Firebase + Stopwatch Logic -->
  <script type="module">
    // ---------- Firebase imports (CDN modular API) ----------
    import { initializeApp } from "https://www.gstatic.com/firebasejs/12.5.0/firebase-app.js";
    import {
      getFirestore,
      doc,
      onSnapshot,
      setDoc,
      serverTimestamp
    } from "https://www.gstatic.com/firebasejs/12.5.0/firebase-firestore.js";

    // ---------- Your Firebase config ----------
    const firebaseConfig = {
      apiKey: "AIzaSyDxlQWFYRcbGZ133HPEMXYy8tR_KMUiJw0",
      authDomain: "lottogame-16083.firebaseapp.com",
      projectId: "lottogame-16083",
      storageBucket: "lottogame-16083.firebasestorage.app",
      messagingSenderId: "278778623701",
      appId: "1:278778623701:web:c7828b036c617a13fa145c"
    };

    // ---------- Init Firebase & Firestore ----------
    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);

    // Global doc for stopwatch state
    // Path: global/stopwatch
    const stateRef = doc(db, "global", "stopwatch");

    // ---------- DOM elements ----------
    const display = document.getElementById("timeDisplay");
    const startStopBtn = document.getElementById("startStopBtn");
    const resetBtn = document.getElementById("resetBtn");
    const statusEl = document.getElementById("status");

    // ---------- Local state (derived from Firestore) ----------
    let latestState = {
      running: false,
      accumulated: 0,   // ms
      startTime: Date.now() // ms epoch
    };

    let animRunning = false;
    let rafId = null;

    // Format ms -> "SSS.TTTTT"
    function formatTime(ms) {
      const totalSeconds = ms / 1000;
      const whole = Math.floor(totalSeconds);
      const fraction = totalSeconds - whole;

      const secStr = String(whole).padStart(3, "0");
      const fracStr = String(Math.floor(fraction * 100000)).padStart(5, "0");

      return `${secStr}.${fracStr}`;
    }

    function getElapsedFromState() {
      const { running, accumulated, startTime } = latestState;
      if (!running) return accumulated;
      const now = Date.now();
      return accumulated + Math.max(0, now - startTime);
    }

    function renderOnce() {
      const elapsed = getElapsedFromState();
      display.textContent = formatTime(elapsed);

      // Button & status text
      startStopBtn.textContent = latestState.running ? "Pause" : "Start";

      const hasTime = getElapsedFromState() > 2; // a few ms buffer
      resetBtn.disabled = !hasTime;

      if (latestState.running) {
        statusEl.textContent = "Running";
      } else if (hasTime) {
        statusEl.textContent = "Paused";
      } else {
        statusEl.textContent = "Ready";
      }
    }

    function loop() {
      if (!animRunning) return;
      display.textContent = formatTime(getElapsedFromState());
      rafId = requestAnimationFrame(loop);
    }

    function ensureAnimationState() {
      if (latestState.running && !animRunning) {
        animRunning = true;
        rafId = requestAnimationFrame(loop);
      } else if (!latestState.running && animRunning) {
        animRunning = false;
        if (rafId) cancelAnimationFrame(rafId);
        rafId = null;
        renderOnce(); // final exact display at pause
      }
    }

    // ---------- Firestore listener (realtime sync) ----------
    onSnapshot(
      stateRef,
      async (snap) => {
        if (!snap.exists()) {
          // Initialize doc once if it doesn't exist
          await setDoc(stateRef, {
            running: false,
            accumulated: 0,
            startTime: Date.now(),
            updatedAt: serverTimestamp()
          });
          return;
        }

        const data = snap.data();

        latestState = {
          running: !!data.running,
          accumulated: typeof data.accumulated === "number" ? data.accumulated : 0,
          startTime: typeof data.startTime === "number" ? data.startTime : Date.now()
        };

        renderOnce();
        ensureAnimationState();
      },
      (error) => {
        console.error("Firestore listener error:", error);
        statusEl.textContent = "Error connecting to server";
      }
    );

    statusEl.textContent = "Connecting…";

    // ---------- Button handlers (write to Firestore) ----------
    async function startGlobal() {
      const now = Date.now();
      await setDoc(
        stateRef,
        {
          running: true,
          // keep accumulated as-is from latestState
          accumulated: latestState.accumulated || 0,
          startTime: now,
          updatedAt: serverTimestamp()
        },
        { merge: true }
      );
    }

    async function pauseGlobal() {
      const now = Date.now();
      const elapsedSinceStart = now - latestState.startTime;
      const newAccumulated =
        (latestState.accumulated || 0) + Math.max(0, elapsedSinceStart);

      await setDoc(
        stateRef,
        {
          running: false,
          accumulated: newAccumulated,
          startTime: latestState.startTime, // keep last start (not really needed)
          updatedAt: serverTimestamp()
        },
        { merge: true }
      );
    }

    async function resetGlobal() {
      await setDoc(
        stateRef,
        {
          running: false,
          accumulated: 0,
          startTime: Date.now(),
          updatedAt: serverTimestamp()
        },
        { merge: true }
      );
    }

    startStopBtn.addEventListener("click", () => {
      if (latestState.running) {
        pauseGlobal();
      } else {
        startGlobal();
      }
    });

    resetBtn.addEventListener("click", () => {
      resetGlobal();
    });
  </script>
</body>
</html>
